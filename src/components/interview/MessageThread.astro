---
import ChallengeDisplay from "./ChallengeDisplay.astro";
import AnswerCard from "./AnswerCard.astro";

type Message = {
  id: string;
  role: string;
  content: string;
  metadata?: Record<string, any>;
}

type Props = {
  messages: Message[];
  role?: string;
  domain?: string;
}

const { messages, role, domain } = Astro.props;
---

<div class="space-y-6 py-4">
  {
    messages.map((msg) => {
      if (msg.role === "system") return null;

      if (msg.role === "interviewer") {
        const isFirst = messages.findIndex((m) => m.role === "interviewer") === messages.indexOf(msg);
        return (
          <div>
            <ChallengeDisplay
              challenge={msg.content}
              role={isFirst ? role : undefined}
              domain={isFirst ? domain : undefined}
              followUp={!isFirst}
            />
          </div>
        );
      }

      if (msg.role === "user") {
        return (
          <AnswerCard
            answer={msg.content}
            quality={msg.metadata?.quality}
            confidence={msg.metadata?.confidence}
            rationale={msg.metadata?.rationale}
          />
        );
      }

      return null;
    })
  }
</div>
