---
type Props = {
  answer: string;
  quality?: string;
  confidence?: number;
  rationale?: string;
}

const { answer, quality, confidence, rationale } = Astro.props;

const qualityLabel = quality === "strong" ? "Strong" : quality === "weak" ? "Weak" : undefined;
const qualityColor = quality === "strong" ? "bg-green-500/20 text-green-300 border-green-500/30" : "bg-amber-500/20 text-amber-300 border-amber-500/30";
---

<div class="mx-auto flex max-w-3xl justify-end px-4">
  <div class="w-[85%]">
    <div class="mb-2 flex items-center justify-end gap-3">
      <span class="text-xs font-medium text-blue-300/70">Your Answer</span>
      {qualityLabel && (
        <span class={`rounded-full border px-2 py-0.5 text-xs font-medium ${qualityColor}`}>
          {qualityLabel}
          {confidence !== undefined && ` · ${Math.round(confidence * 100)}%`}
        </span>
      )}
    </div>

    <div class="rounded-2xl border border-blue-500/20 bg-blue-500/10 p-6 backdrop-blur-xl">
      <div class="prose prose-invert max-w-none text-blue-100/90 whitespace-pre-wrap leading-relaxed">
        {answer}
      </div>
    </div>

    {rationale && (
      <div class="mt-2 rounded-lg border border-blue-500/15 bg-blue-500/5 px-4 py-2 text-right">
        <p class="text-xs text-blue-100/50">
          <span class="font-medium">Evaluator note:</span> {rationale}
        </p>
      </div>
    )}
  </div>
</div>
