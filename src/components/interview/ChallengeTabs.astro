---
type Props = {
  challenges: Array<{ id: string; status: string }>;
  activeId: string;
  sessionId: string;
};

const { challenges, activeId, sessionId } = Astro.props;
---

<div class="flex-shrink-0 border-l border-white/10 bg-white/[0.02] p-3">
  <p class="mb-2 text-xs font-medium text-blue-100/40">Challenges</p>
  <div class="space-y-1">
    {challenges.map((c, i) => {
      const isActive = c.id === activeId;
      const isCompleted = c.status === "completed";
      return (
        <a
          href={`/interview/${sessionId}?challenge=${c.id}`}
          class={`block rounded-lg px-3 py-2 text-xs transition-colors ${
            isActive
              ? "bg-purple-600/20 text-white ring-1 ring-purple-500/30"
              : "text-blue-100/60 hover:bg-white/5 hover:text-white"
          }`}
        >
          <span>Challenge {i + 1}</span>
          {isCompleted && (
            <span class="ml-2 rounded-full border border-green-500/30 bg-green-500/15 px-1.5 py-0.5 text-[10px] text-green-300">
              Done
            </span>
          )}
        </a>
      );
    })}
  </div>
</div>
