---
interface Props {
  challenge: string;
  role?: string;
  domain?: string;
  followUp?: boolean;
}

const { challenge, role, domain, followUp } = Astro.props;
const heading = followUp ? "Follow-up" : role && domain ? `${role} — ${domain}` : "Your Challenge";
---

<div class="mx-auto max-w-3xl px-4">
  <div class="mb-2">
    <span class="text-xs font-medium text-purple-300/70">{heading}</span>
  </div>

  <div class="rounded-2xl border border-purple-500/20 bg-purple-500/10 p-6 backdrop-blur-xl">
    <div class="prose prose-invert max-w-none text-blue-100/90 whitespace-pre-wrap leading-relaxed">
      {challenge}
    </div>
  </div>
</div>
