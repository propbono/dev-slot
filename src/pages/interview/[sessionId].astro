---
import Layout from "@/layouts/Layout.astro";
import AnswerEditor from "@/components/interview/AnswerEditor";
import MessageThread from "@/components/interview/MessageThread.astro";
import GenerationSkeleton from "@/components/interview/GenerationSkeleton";
import SessionHeader from "@/components/interview/SessionHeader.astro";
import PerformanceCard from "@/components/interview/PerformanceCard.astro";
import ChallengeComplete from "@/components/interview/ChallengeComplete.astro";
import ChallengeTabs from "@/components/interview/ChallengeTabs.astro";
import { createClient } from "@/lib/supabase";

const { sessionId } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/new-session?error=not_configured");

const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) return Astro.redirect("/auth/signin");

// Check session exists and belongs to user
const { data: session } = await supabase
  .from("sessions")
  .select("id, status, updated_at")
  .eq("id", sessionId)
  .eq("user_id", user.id)
  .single();

if (!session) {
  return new Response("Session not found or access denied", {
    status: 404,
    headers: { "Content-Type": "text/plain" },
  });
}

// Fetch committed messages for this session
const { data: messages } = await supabase
  .from("session_messages")
  .select("id, role, content, metadata, challenge_id, created_at")
  .eq("session_id", sessionId)
  .eq("status", "committed")
  .order("created_at");

// Query all challenges for this session
const { data: challenges } = await supabase
  .from("challenges")
  .select("id, status, created_at")
  .eq("session_id", sessionId)
  .order("created_at");

// Determine active challenge from query param or default to latest
const queryChallenge = Astro.url.searchParams.get("challenge");
const activeChallengeId =
  queryChallenge && challenges?.some((c) => c.id === queryChallenge)
    ? queryChallenge
    : (challenges?.[challenges.length - 1]?.id ?? "");

// Filter messages by active challenge
const challengeMessages = (messages ?? []).filter((m) => m.challenge_id === activeChallengeId);

const showSkeleton = challengeMessages.filter((m) => m.role === "interviewer").length === 0;

// Check if active challenge is completed
const { data: activeChallenge } = await supabase
  .from("challenges")
  .select("id, status, summary")
  .eq("session_id", sessionId)
  .eq("status", "completed")
  .order("created_at", { ascending: false })
  .limit(1)
  .single();

const challengeCompleted = !!activeChallenge;

// Parse role + domain from system message (when messages exist)
const systemMsg = challengeMessages.find((m) => m.role === "system");
let role: string | undefined;
let domain: string | undefined;
if (systemMsg) {
  try {
    const constraints = JSON.parse(systemMsg.content);
    role = constraints.role_level;
    domain = constraints.domain;
  } catch {
    /* ignore parse errors */
  }
}

// Fetch draft for this session (if any) to pre-fill editor
const { data: drafts } = await supabase
  .from("session_messages")
  .select("content")
  .eq("session_id", sessionId)
  .eq("role", "user")
  .eq("status", "draft")
  .order("created_at", { ascending: false })
  .limit(1);

const draftContent = drafts?.[0]?.content ?? undefined;

const error = Astro.url.searchParams.get("error");
const errorMessages: Record<string, string> = {
  missing_fields: "Please provide both a session and an answer.",
  missing_context: "Could not load interview context. Please try again.",
  invalid_context: "Session data is corrupted. Start a new session.",
};
const evaluationError = error ? (errorMessages[error] ?? "An unexpected error occurred. Please try again.") : undefined;
---

<Layout title={showSkeleton ? "Generating — DevSlot" : "Interview — DevSlot"}>
  <div class="bg-cosmic relative min-h-screen w-full">
    <div class="py-8">
      {
        showSkeleton ? (
          <GenerationSkeleton sessionId={sessionId!} client:load />
        ) : (
          <div class="flex gap-0">
            <div class="flex-1">
              <SessionHeader role={role} domain={domain} sessionId={sessionId!} status={session.status} />
              {session.status !== "active" && (
                <div class="mx-auto max-w-3xl px-4 pt-4">
                  <div class="rounded-lg border border-green-500/20 bg-green-500/10 px-4 py-2 text-center">
                    <span class="text-sm font-medium text-green-300">Session Complete</span>
                    <span class="ml-2 text-xs text-green-400/60">
                      {new Date(session.updated_at).toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                      })}
                    </span>
                  </div>
                </div>
              )}
              {session.status !== "active" && <PerformanceCard messages={challengeMessages} />}
              <MessageThread messages={challengeMessages} role={role} domain={domain} />
              {challengeCompleted && activeChallenge?.summary ? (
                <ChallengeComplete summary={activeChallenge.summary} sessionId={sessionId!} />
              ) : (
                session.status === "active" && (
                  <AnswerEditor
                    sessionId={sessionId!}
                    initialDraft={draftContent}
                    evaluationError={evaluationError}
                    client:load
                  />
                )
              )}
            </div>
            {(challenges ?? []).length > 1 && (
              <ChallengeTabs challenges={challenges!} activeId={activeChallengeId} sessionId={sessionId!} />
            )}
          </div>
        )
      }
    </div>
  </div>
</Layout>
