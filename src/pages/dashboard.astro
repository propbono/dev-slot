---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import JDInput from "@/components/interview/JDInput";

const error = Astro.url.searchParams.get("error") ?? undefined;
---

<Layout title="Dashboard — DevSlot">
  <div class="bg-cosmic relative min-h-screen w-full overflow-hidden">
    <div class="relative z-10 p-4 sm:p-8">
      <Topbar />
      <JDInput error={error} client:load />
    </div>
  </div>
</Layout>
